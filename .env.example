# Database (Neon PostgreSQL - get from neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# AI Provider - GitHub Models (get token from github.com/settings/tokens)
# Can swap to OpenAI by changing lib/ai/classify.ts: AI_BASE_URL and AI_MODEL
GITHUB_TOKEN="ghp_your_token_here"

# Cron secret - generate with: openssl rand -base64 32
# Set this in Vercel dashboard under Environment Variables
CRON_SECRET="your_random_secret_here"

# Optional: Next.js public URL (set by Vercel automatically)
# NEXT_PUBLIC_URL="https://your-deployment.vercel.app"

# NewsAPI (newsapi.org) — get a free key at newsapi.org/register
NEWS_API_KEY="your_newsapi_key_here"

# Clerk authentication (clerk.com) — for /admin route protection
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your_key_here"
CLERK_SECRET_KEY="sk_test_your_key_here"

# Cloudflare Turnstile (turnstile.com) — for report form CAPTCHA protection
NEXT_PUBLIC_TURNSTILE_SITE_KEY="your_site_key_here"
TURNSTILE_SECRET_KEY="your_secret_key_here"
